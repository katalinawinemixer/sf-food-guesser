# Copy this file to .env, then replace placeholders with keys you own.
# Never commit .env. This example intentionally contains no real API keys.

# REQUIRED for local photo analysis. Use your own OpenRouter key.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# OPTIONAL comma-separated OpenRouter vision model ids to try if the primary
# model is rate-limited or unavailable. Use model ids, not API keys.
OPENROUTER_FALLBACK_MODELS=

# OPTIONAL direct OpenAI fallback. Leave blank unless you have your own key.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# OPTIONAL official Google Places API (New) photo provider. Leave blank unless
# you have your own Google Places API key. When present, this is used before
# HasData or SerpAPI.
GOOGLE_PLACES_API_KEY=

# OPTIONAL cost-optimized Google Maps customer/review photo provider. Leave
# blank unless you have your own HasData key. When present and Google Places is
# not configured, the backend uses HasData for Google Maps place search and
# Google Maps photos before falling back to SerpAPI.
HASDATA_API_KEY=

# OPTIONAL legacy Google Maps customer/review photo provider. Leave blank unless
# you have your own SerpAPI key. Used only when GOOGLE_PLACES_API_KEY and
# HASDATA_API_KEY are not present.
SERPAPI_API_KEY=

# OPTIONAL low-cost web/review-page search provider. Leave blank unless you have
# your own Ceramic key. When present, the backend uses Ceramic for broad web
# evidence before falling back to Exa for web search.
CERAMIC_API_KEY=

# OPTIONAL article/review-page search provider. Leave blank unless you have your
# own Exa key. When present, the backend uses Exa article discovery and, if no
# Ceramic key is present, Exa deep search with highlights.
EXA_API_KEY=

# OPTIONAL local deterministic visual-signature comparison for uploaded photos
# against provider-returned public photos. No API key required.
# Supported value: local-signature
IMAGE_EMBEDDING_PROVIDER=

# OPTIONAL local provider search cache TTL in milliseconds. This is used for
# non-Google search providers only.
SF_FOOD_SEARCH_CACHE_TTL_MS=1800000

# Local Express API port.
SF_FOOD_GUESSER_API_PORT=5174

# OPTIONAL comma-separated frontend origins allowed to call the API when the
# backend is hosted separately. Local Vite origins are allowed automatically.
# Example: https://sf-food-guesser.pages.dev,https://www.your-domain.com
SF_FOOD_GUESSER_ALLOWED_ORIGINS=

# OPTIONAL frontend API base URL for deployed static frontends. Leave blank for
# local Vite proxy/same-origin API calls. For Cloudflare Pages, set this in the
# Pages build environment if the API is hosted separately.
VITE_API_BASE_URL=
