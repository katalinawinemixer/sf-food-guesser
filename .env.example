# Use either OpenRouter or OpenAI. OpenRouter keys start with sk-or-.
OPENROUTER_API_KEY=replace_me
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# Optional direct OpenAI fallback.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional, but needed for true review/photo-page comparison. When present, the
# backend generates search queries, fetches candidate public photos, and asks
# the vision model to compare those images against the upload.
SERPAPI_API_KEY=

# Optional web/review-page search provider.
EXA_API_KEY=

SF_FOOD_GUESSER_API_PORT=5174
