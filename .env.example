# Copy this file to .env, then replace placeholders with keys you own.
# Never commit .env. This file intentionally contains no real API keys.

# REQUIRED for the current app setup. Replace this placeholder with your
# OpenRouter key.
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# OPTIONAL direct OpenAI fallback. Leave blank unless you have your own key.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# OPTIONAL photo-search provider. Leave blank unless you have your own SerpAPI
# key. When present, the backend fetches candidate public photos and asks the
# vision model to compare those images against the upload.
SERPAPI_API_KEY=

# OPTIONAL web/review-page search provider. Leave blank unless you have your own
# Exa key.
EXA_API_KEY=

SF_FOOD_GUESSER_API_PORT=5174
