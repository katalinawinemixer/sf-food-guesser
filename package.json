{
  "name": "sf-food-guesser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"node server.mjs\" \"vite --host 127.0.0.1\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node server.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "secret-scan": "node scripts/secret-scan.mjs",
    "evaluate": "node scripts/evaluate.mjs",
    "test": "vitest run && npm run lint && node --check server.mjs && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "exa-js": "^2.13.0",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "multer": "^2.1.1",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
